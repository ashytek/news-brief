# Copy this file to .env and fill in your keys
# Never commit .env to git

SUPABASE_URL=https://mvrmcptahvwmfvnwlvyd.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Apify — primary transcript source (~$0.001/video). Without this, transcripts
# fall through to the free local chain (yt-dlp -> timedtext -> AssemblyAI).
# Sign up at https://apify.com (no card needed) -> Settings -> API tokens.
APIFY_TOKEN=your_apify_token_here

ANTHROPIC_API_KEY=your_anthropic_key_here

# Google AI Studio key — used for embeddings (free tier is generous)
# Get it at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_ai_studio_key_here

YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# Optional - only needed if YouTube transcripts are unavailable
ASSEMBLYAI_API_KEY=your_assemblyai_key_here
